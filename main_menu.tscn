[gd_scene format=3 uid="uid://main_menu_scene"]

[ext_resource type="Script" path="res://main_menu.gd" id="1_menu"]

[node name="MainMenu" type="Control"]
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1_menu")

[node name="Background" type="ColorRect" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.039, 0.027, 0.118, 1)

[node name="VBox" type="VBoxContainer" parent="."]
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -240.0
offset_top = -220.0
offset_right = 240.0
offset_bottom = 230.0
theme_override_constants/separation = 20
alignment = 1

[node name="Title" type="Label" parent="VBox"]
text = "RACING DODGIO"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 64
theme_override_colors/font_color = Color(1.0, 0.851, 0.102, 1)

[node name="Subtitle" type="Label" parent="VBox"]
text = "Overland Park, KS"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.533, 0.533, 0.667, 1)

[node name="Spacer" type="Control" parent="VBox"]
custom_minimum_size = Vector2(0, 30)

[node name="StartButton" type="Button" parent="VBox"]
custom_minimum_size = Vector2(260, 60)
text = ">> START RACE <<"
theme_override_font_sizes/font_size = 28

[node name="Controls" type="Label" parent="VBox"]
text = "Arrow keys to steer  —  UP / DOWN to accelerate / brake"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 16
theme_override_colors/font_color = Color(0.533, 0.533, 0.667, 1)

[node name="Instr2" type="Label" parent="VBox"]
text = "Collect  [*]  stars for a 5-second speed boost"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 16
theme_override_colors/font_color = Color(0.533, 0.533, 0.667, 1)

[node name="Instr3" type="Label" parent="VBox"]
text = "Dodge road blocks — you stall for 2 seconds"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 16
theme_override_colors/font_color = Color(0.533, 0.533, 0.667, 1)

[connection signal="pressed" from="VBox/StartButton" to="." method="_on_start_pressed"]

[gd_scene format=3 uid="uid://main_menu_scene"]

[ext_resource type="Script" path="res://main_menu.gd" id="1_menu"]

[node name="MainMenu" type="Control"]
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1_menu")

[node name="Background" type="ColorRect" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.039, 0.027, 0.118, 1)

[node name="VBox" type="VBoxContainer" parent="."]
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -280.0
offset_top = -260.0
offset_right = 280.0
offset_bottom = 260.0
theme_override_constants/separation = 14
alignment = 1

[node name="Title" type="Label" parent="VBox"]
text = "RACING DODGIO"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 52
theme_override_colors/font_color = Color(1.0, 0.851, 0.102, 1)

[node name="Subtitle" type="Label" parent="VBox"]
text = "CHOOSE YOUR CAR"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 18
theme_override_colors/font_color = Color(0.3, 0.95, 1.0, 1)

[node name="CarRow" type="HBoxContainer" parent="VBox"]
custom_minimum_size = Vector2(0, 130)
theme_override_constants/separation = 10
alignment = 1

[node name="NavHint" type="Label" parent="VBox"]
text = "< A / D >"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 14
theme_override_colors/font_color = Color(0.533, 0.533, 0.667, 1)

[node name="SelectedName" type="Label" parent="VBox"]
text = "RED CAR"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 26
theme_override_colors/font_color = Color(1.0, 0.851, 0.102, 1)

[node name="StatsBox" type="VBoxContainer" parent="VBox"]
theme_override_constants/separation = 6

[node name="SpeedRow" type="HBoxContainer" parent="VBox/StatsBox"]
theme_override_constants/separation = 10
alignment = 1

[node name="SpeedLabel" type="Label" parent="VBox/StatsBox/SpeedRow"]
custom_minimum_size = Vector2(70, 0)
text = "SPEED"
theme_override_font_sizes/font_size = 14
theme_override_colors/font_color = Color(0.533, 0.533, 0.667, 1)

[node name="SpeedBar" type="ProgressBar" parent="VBox/StatsBox/SpeedRow"]
custom_minimum_size = Vector2(200, 18)
max_value = 8.0
value = 6.0
show_percentage = false

[node name="StyleRow" type="HBoxContainer" parent="VBox/StatsBox"]
theme_override_constants/separation = 10
alignment = 1

[node name="StyleLabel" type="Label" parent="VBox/StatsBox/StyleRow"]
custom_minimum_size = Vector2(70, 0)
text = "STYLE"
theme_override_font_sizes/font_size = 14
theme_override_colors/font_color = Color(0.533, 0.533, 0.667, 1)

[node name="StyleBar" type="ProgressBar" parent="VBox/StatsBox/StyleRow"]
custom_minimum_size = Vector2(200, 18)
max_value = 8.0
value = 5.0
show_percentage = false

[node name="LuckRow" type="HBoxContainer" parent="VBox/StatsBox"]
theme_override_constants/separation = 10
alignment = 1

[node name="LuckLabel" type="Label" parent="VBox/StatsBox/LuckRow"]
custom_minimum_size = Vector2(70, 0)
text = "LUCK"
theme_override_font_sizes/font_size = 14
theme_override_colors/font_color = Color(0.533, 0.533, 0.667, 1)

[node name="LuckBar" type="ProgressBar" parent="VBox/StatsBox/LuckRow"]
custom_minimum_size = Vector2(200, 18)
max_value = 8.0
value = 4.0
show_percentage = false

[node name="DifficultyRow" type="HBoxContainer" parent="VBox"]
alignment = 1
theme_override_constants/separation = 10

[node name="DiffLabel" type="Label" parent="VBox/DifficultyRow"]
text = "DIFFICULTY:"
theme_override_font_sizes/font_size = 14
theme_override_colors/font_color = Color(0.533, 0.533, 0.667, 1)

[node name="EasyBtn" type="Button" parent="VBox/DifficultyRow"]
custom_minimum_size = Vector2(80, 32)
text = "EASY"
theme_override_font_sizes/font_size = 14

[node name="NormalBtn" type="Button" parent="VBox/DifficultyRow"]
custom_minimum_size = Vector2(80, 32)
text = "NORMAL"
theme_override_font_sizes/font_size = 14

[node name="HardBtn" type="Button" parent="VBox/DifficultyRow"]
custom_minimum_size = Vector2(80, 32)
text = "HARD"
theme_override_font_sizes/font_size = 14

[node name="Spacer" type="Control" parent="VBox"]
custom_minimum_size = Vector2(0, 4)

[node name="ButtonRow" type="HBoxContainer" parent="VBox"]
alignment = 1
theme_override_constants/separation = 16

[node name="QuickRaceButton" type="Button" parent="VBox/ButtonRow"]
custom_minimum_size = Vector2(220, 52)
text = ">> QUICK RACE <<"
theme_override_font_sizes/font_size = 22

[node name="CircuitButton" type="Button" parent="VBox/ButtonRow"]
custom_minimum_size = Vector2(220, 52)
text = "CIRCUIT MODE"
theme_override_font_sizes/font_size = 22

[node name="Controls" type="Label" parent="VBox"]
text = "WASD / Arrows to drive  |  Stars = Boost  |  Dodge Jeeps"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 13
theme_override_colors/font_color = Color(0.40, 0.40, 0.55, 1)

[connection signal="pressed" from="VBox/DifficultyRow/EasyBtn" to="." method="_on_diff_easy"]
[connection signal="pressed" from="VBox/DifficultyRow/NormalBtn" to="." method="_on_diff_normal"]
[connection signal="pressed" from="VBox/DifficultyRow/HardBtn" to="." method="_on_diff_hard"]
[connection signal="pressed" from="VBox/ButtonRow/QuickRaceButton" to="." method="_on_quick_race_pressed"]
[connection signal="pressed" from="VBox/ButtonRow/CircuitButton" to="." method="_on_circuit_pressed"]
